# Required
DATABASE_URL=postgresql+asyncpg://bus:bus@localhost:5433/bus
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me

# Optional — Email (SMTP); required when using the email channel
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# Optional — SMS (MSG91); required when using the SMS channel
# MSG91_API_KEY=
# MSG91_SENDER_ID=
# MSG91_TEMPLATE_ID=

# Optional (defaults shown)
LOG_LEVEL=INFO
WORKER_CONCURRENCY=4
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=60
